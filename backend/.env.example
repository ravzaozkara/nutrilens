# PostgreSQL Bağlantısı
DATABASE_URL=postgresql://user:pass@host:5432/db

# JWT Güvenlik Anahtarı — üretmek için: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=GENERATE_WITH_secrets.token_urlsafe_64

# JWT Ayarları
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — virgülle ayrılmış izinli kaynak listesi
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# AI Model Yolu
MODEL_PATH=model/best_model_final.pth

# Güven Eşiği (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.50

# Maksimum Görsel Boyutu (MB)
MAX_IMAGE_SIZE_MB=10
